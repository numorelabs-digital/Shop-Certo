rules_version = '2';
service cloud.firestore { match /databases/{database}/documents {
  function signedIn(){return request.auth != null;}
  function owner(uid){return signedIn() && request.auth.uid == uid;}
  match /users/{uid}{allow read,create,update,delete:if owner(uid);match /{document=**}{allow read,write:if owner(uid);}}
  match /offers/{offerId}{allow read:if true;allow write:if false;}
  match /system/{document=**}{allow read:if true;allow write:if false;}
  match /{document=**}{allow read,write:if false;}
}}
